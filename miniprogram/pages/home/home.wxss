.home-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 42rpx 34rpx 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(150deg, #fffdf8 0%, #edf3e8 62%, #f6ead5 100%);
  box-shadow: 0 18rpx 48rpx rgba(62, 55, 42, 0.08);
}

.hero-copy {
  position: relative;
  z-index: 2;
}

.hero-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-trust {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.trust-item {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.78);
  color: #496553;
  font-size: 23rpx;
  font-weight: 700;
}

.hero-visual {
  position: relative;
  margin-top: 32rpx;
  min-height: 300rpx;
}

.brand-card {
  position: relative;
  z-index: 2;
  width: 72%;
  padding: 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.92);
  box-shadow: 0 16rpx 34rpx rgba(55, 48, 36, 0.08);
}

.brand-kicker {
  color: #6d8b74;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.brand-title {
  margin-top: 10rpx;
  padding-right: 82rpx;
  color: #24352b;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.45;
}

.brand-mark {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  display: flex;
  width: 70rpx;
  height: 70rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #6d8b74;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.collage {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 290rpx;
  height: 270rpx;
}

.collage-image {
  position: absolute;
  display: block;
  border: 8rpx solid rgba(255, 253, 248, 0.9);
  border-radius: 24rpx;
  background: #e8ede2;
  box-shadow: 0 12rpx 28rpx rgba(55, 48, 36, 0.12);
}

.collage-one {
  right: 16rpx;
  bottom: 24rpx;
  width: 190rpx;
  height: 136rpx;
  transform: rotate(4deg);
}

.collage-two {
  left: 8rpx;
  top: 12rpx;
  width: 142rpx;
  height: 112rpx;
  transform: rotate(-7deg);
}

.collage-three {
  right: 0;
  top: 0;
  width: 154rpx;
  height: 120rpx;
  transform: rotate(7deg);
}

.home-contact-bar {
  display: flex;
  gap: 14rpx;
}

.stat-row {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(60, 50, 35, 0.05);
}

.stat-number {
  color: #6d8b74;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
}

.stat-label {
  margin-top: 8rpx;
  color: #67645d;
  font-size: 24rpx;
}

.service-card {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.service-mark {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(109, 139, 116, 0.14);
  color: #496553;
  font-weight: 700;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #fffdf8;
}

.timeline-index {
  width: 76rpx;
  flex-shrink: 0;
  color: #6d8b74;
  font-size: 30rpx;
  font-weight: 700;
}

.contact-mini {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.service-more {
  margin-top: 6rpx;
}

.sticky-contact {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  z-index: 10;
  display: flex;
  gap: 12rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(55, 48, 36, 0.16);
}

.sticky-main,
.sticky-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  line-height: 1.2;
}

.sticky-main {
  flex: 1.4;
  background: #6d8b74;
  color: #ffffff;
}

.sticky-ghost {
  flex: 1;
  background: #f4f0e7;
  color: #496553;
}
