<view class="page">
  <view class="home-hero">
    <view class="hero-copy">
      <view class="eyebrow">{{home.hero.eyebrow}}</view>
      <view class="hero-title">{{home.hero.title}}</view>
      <view class="hero-text">{{home.hero.text}}</view>

      <view class="hero-actions">
        <button class="action-button" hover-class="tap-active" bindtap="feedback" open-type="contact">微信咨询</button>
        <button class="ghost-button" hover-class="tap-active" bindtap="goServices">了解服务</button>
      </view>

      <view class="hero-trust">
        <view class="trust-item" wx:for="{{home.trust}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <view class="hero-visual">
      <view class="brand-card">
        <view class="brand-kicker">Songjing Psychology</view>
        <view class="brand-title">给每一段需要被理解的时刻，一个安静的空间。</view>
        <view class="brand-mark">松</view>
      </view>
      <view class="collage">
        <image class="collage-image collage-one" src="/assets/images/collage-room.svg" mode="aspectFill"></image>
        <image class="collage-image collage-two" src="/assets/images/collage-calm.svg" mode="aspectFill"></image>
        <image class="collage-image collage-three" src="/assets/images/collage-conversation.svg" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <view class="section home-contact-bar">
    <button class="action-button" hover-class="tap-active" bindtap="feedback" open-type="contact">添加客服</button>
    <button class="ghost-button" hover-class="tap-active" bindtap="callPhone">拨打电话</button>
    <button class="ghost-button" hover-class="tap-active" bindtap="goContact">地图地址</button>
  </view>

  <view class="section stat-row">
    <view class="stat-card" wx:for="{{home.stats}}" wx:key="label">
      <view class="stat-number">{{item.number}}</view>
      <view class="stat-label">{{item.label}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">当这些感受反复出现，咨询可以成为一个开始</view>
    <view class="card" wx:for="{{home.issues}}" wx:key="title">
      <view class="card-title">{{index + 1}}. {{item.title}}</view>
      <view class="card-text">{{item.text}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">我们的服务</view>
    <view class="service-card" wx:for="{{home.services}}" wx:key="title">
      <view class="service-mark">{{index + 1}}</view>
      <view>
        <view class="card-title">{{item.title}}</view>
        <view class="card-text">{{item.text}}</view>
      </view>
    </view>
    <button class="ghost-button wide-button service-more" hover-class="tap-active" bindtap="goServices">查看全部服务</button>
  </view>

  <view class="section">
    <view class="section-title">咨询流程清晰，第一次联系也不用紧张</view>
    <view class="timeline-item" wx:for="{{home.process}}" wx:key="title">
      <view class="timeline-index">0{{index + 1}}</view>
      <view>
        <view class="card-title">{{item.title}}</view>
        <view class="card-text">{{item.text}}</view>
      </view>
    </view>
  </view>

  <view class="card contact-mini">
    <view>
      <view class="card-title">如果您正在犹豫，可以先从一次沟通开始</view>
      <view class="card-text">电话：{{contact.phone}}</view>
      <view class="card-text">邮箱：{{contact.email}}</view>
    </view>
    <button class="action-button wide-button" hover-class="tap-active" bindtap="goContact">联系松境心理</button>
  </view>

  <view class="bottom-safe-space"></view>

  <view class="sticky-contact">
    <button class="sticky-main" hover-class="tap-active" bindtap="feedback" open-type="contact">微信咨询</button>
    <button class="sticky-ghost" hover-class="tap-active" bindtap="callPhone">电话</button>
    <button class="sticky-ghost" hover-class="tap-active" bindtap="goContact">地址</button>
  </view>
</view>
