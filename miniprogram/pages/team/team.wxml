<view class="page">
  <view class="hero">
    <view class="eyebrow">Team</view>
    <view class="hero-title">咨询师团队</view>
    <view class="hero-text">我们是一群志同道合的伙伴，希望以专业、真诚的心理咨询支持每一位正在经历困扰的人。</view>
  </view>

  <view class="section">
    <view class="section-title">创始人</view>
    <view class="card founder-card">
      <view class="card-title">{{founder.name}}</view>
      <view class="team-title">{{founder.title}}</view>
      <view class="pill-row founder-stats">
        <view class="pill" wx:for="{{founder.stats}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="card-text">{{founder.summary}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">咨询师介绍</view>
    <view class="filter-panel">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{activeFilter === item.key ? 'filter-chip-active' : ''}}"
        hover-class="tap-active"
        data-filter="{{item.key}}"
        bindtap="changeFilter"
      >
        <view class="filter-label">{{item.label}}</view>
      </view>
    </view>

    <view class="counselor-card" wx:for="{{filteredCounselors}}" wx:key="name">
      <view class="avatar-wrap">
        <image class="counselor-image" src="{{item.avatarImage}}" mode="aspectFill"></image>
      </view>
      <view class="counselor-body">
        <view class="counselor-head">
          <view>
            <view class="card-title">{{item.name}}</view>
            <view class="team-title">松境心理认证心理咨询师</view>
          </view>
          <view class="counselor-badge">咨询师</view>
        </view>
        <view class="pill-row">
          <view class="pill" wx:for="{{item.formats}}" wx:for-item="format" wx:key="*this">{{format}}</view>
        </view>
        <view class="expertise">擅长方向：{{item.expertise}}</view>
        <view class="quote">{{item.quote}}</view>
      </view>
    </view>

    <button wx:if="{{hasMore}}" class="ghost-button wide-button load-more" hover-class="tap-active" bindtap="loadMore">查看更多咨询师</button>
  </view>

  <button class="action-button wide-button" hover-class="tap-active" bindtap="feedback" open-type="contact">联系咨询顾问</button>
</view>
