.team-title {
  margin: 0 0 16rpx;
  color: #6d8b74;
  font-size: 24rpx;
  font-weight: 700;
}

.founder-stats {
  margin-bottom: 18rpx;
}

.counselor-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 20rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.counselor-image {
  width: 190rpx;
  height: 250rpx;
  flex-shrink: 0;
  background: #edf3e8;
}

.counselor-body {
  flex: 1;
  padding: 24rpx;
}

.expertise {
  margin-top: 16rpx;
  color: #4f554c;
  font-size: 25rpx;
  line-height: 1.55;
}

.quote {
  margin-top: 14rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #d5b47d;
  color: #76736c;
  font-size: 24rpx;
  line-height: 1.55;
}
