.team-title {
  margin: 0 0 16rpx;
  color: #6d8b74;
  font-size: 24rpx;
  font-weight: 700;
}

.founder-stats {
  margin-bottom: 18rpx;
}

.filter-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 26rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(109, 139, 116, 0.14);
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.7);
}

.filter-chip {
  display: flex;
  width: calc(50% - 7rpx);
  min-height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #fffdf8;
  color: #496553;
  box-sizing: border-box;
  box-shadow: 0 8rpx 22rpx rgba(60, 50, 35, 0.04);
}

.filter-label {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
}

.filter-chip-active {
  background: #6d8b74;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(109, 139, 116, 0.22);
}

.counselor-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 20rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.counselor-image {
  width: 190rpx;
  height: 250rpx;
  flex-shrink: 0;
  background: #edf3e8;
}

.counselor-body {
  flex: 1;
  padding: 24rpx;
}

.expertise {
  margin-top: 16rpx;
  color: #4f554c;
  font-size: 25rpx;
  line-height: 1.55;
}

.quote {
  margin-top: 14rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #d5b47d;
  color: #76736c;
  font-size: 24rpx;
  line-height: 1.55;
}

.load-more {
  margin-top: 8rpx;
}
