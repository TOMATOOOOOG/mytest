.team-title {
  margin: 0 0 16rpx;
  color: #6d8b74;
  font-size: 24rpx;
  font-weight: 700;
}

.founder-stats {
  margin-bottom: 18rpx;
}

.filter-panel {
  display: flex;
  gap: 8rpx;
  margin-bottom: 26rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(109, 139, 116, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.7);
}

.filter-chip {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  color: #496553;
  box-sizing: border-box;
}

.filter-label {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.filter-chip-active {
  background: #6d8b74;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(109, 139, 116, 0.22);
}

.counselor-card {
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(60, 50, 35, 0.05);
}

.avatar-wrap {
  width: 132rpx;
  height: 132rpx;
  flex: none;
  padding: 8rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(109, 139, 116, 0.22), rgba(213, 180, 125, 0.26));
  box-sizing: border-box;
}

.counselor-image {
  display: block;
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #edf3e8;
}

.counselor-body {
  flex: 1;
  min-width: 0;
}

.counselor-head {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.counselor-badge {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(109, 139, 116, 0.12);
  color: #6d8b74;
  font-size: 22rpx;
  font-weight: 700;
}

.expertise {
  margin-top: 16rpx;
  color: #4f554c;
  font-size: 25rpx;
  line-height: 1.55;
}

.quote {
  margin-top: 14rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #d5b47d;
  color: #76736c;
  font-size: 24rpx;
  line-height: 1.55;
}

.load-more {
  margin-top: 8rpx;
}
