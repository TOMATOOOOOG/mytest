.direction-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.direction-index {
  flex: none;
  width: 70rpx;
  color: #6d8b74;
  font-size: 30rpx;
  font-weight: 700;
}

.stage-timeline {
  position: relative;
}

.stage-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 18rpx;
  padding: 0;
  background: transparent;
}

.stage-dot {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #6d8b74;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.stage-body {
  flex: 1;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #fffdf8;
}

.process-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.process-step {
  display: flex;
  width: calc(50% - 7rpx);
  min-height: 96rpx;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(109, 139, 116, 0.12);
  box-sizing: border-box;
}

.process-number {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fffdf8;
  color: #496553;
  font-size: 23rpx;
  font-weight: 700;
}

.process-name {
  color: #496553;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.format-card {
  display: flex;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fffdf8;
}

.format-mark {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(109, 139, 116, 0.12);
  color: #6d8b74;
  font-weight: 700;
}

.notice {
  position: relative;
  margin-bottom: 16rpx;
  padding-left: 28rpx;
  color: #67645d;
  font-size: 27rpx;
}

.notice::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #6d8b74;
}

.faq-card {
  overflow: hidden;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.faq-question {
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  color: #24352b;
  font-weight: 700;
}

.faq-toggle {
  flex: none;
  color: #6d8b74;
  font-size: 23rpx;
}

.faq-answer {
  padding: 0 28rpx 26rpx;
  color: #67645d;
  font-size: 27rpx;
}
