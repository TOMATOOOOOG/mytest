<view class="page">
  <view class="hero">
    <view class="eyebrow">Services</view>
    <view class="hero-title">我们的服务</view>
    <view class="hero-text">{{services.intro}}</view>
  </view>

  <view class="section">
    <view class="section-title">松境咨询能够为您解决什么</view>
    <view class="direction-card" wx:for="{{services.directions}}" wx:key="title">
      <view class="direction-index">0{{index + 1}}</view>
      <view>
        <view class="card-title">{{item.title}}</view>
        <view class="card-text">{{item.text}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">了解咨询阶段</view>
    <view class="stage-timeline">
      <view class="stage-card" wx:for="{{services.stages}}" wx:key="title">
        <view class="stage-dot">{{index + 1}}</view>
        <view class="stage-body">
          <view class="card-title">{{item.title}}</view>
          <view class="card-text">{{item.text}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">专业咨询流程</view>
    <view class="process-grid">
      <view class="process-step" wx:for="{{services.process}}" wx:key="*this">
        <view class="process-number">{{index + 1}}</view>
        <view class="process-name">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">服务形式</view>
    <view class="format-card" wx:for="{{services.formats}}" wx:key="*this">
      <view class="format-mark">松</view>
      <view class="card-title">{{item}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">咨询须知</view>
    <view class="notice" wx:for="{{services.notices}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="section">
    <view class="section-title">常见问题</view>
    <view class="faq-card" wx:for="{{services.faq}}" wx:key="question">
      <view class="faq-question" data-index="{{index}}" bindtap="toggleFaq">
        <view>{{item.question}}</view>
        <view class="faq-toggle" wx:if="{{openFaqIndex === index}}">收起</view>
        <view class="faq-toggle" wx:else>展开</view>
      </view>
      <view class="faq-answer" wx:if="{{openFaqIndex === index}}">{{item.answer}}</view>
    </view>
  </view>

  <button class="action-button wide-button" hover-class="tap-active" bindtap="callPhone">联系咨询顾问</button>

  <view class="bottom-safe-space"></view>

  <view class="sticky-contact">
    <button class="sticky-main" hover-class="tap-active" bindtap="feedback" open-type="contact">微信咨询</button>
    <button class="sticky-ghost" hover-class="tap-active" bindtap="callPhone">电话</button>
    <button class="sticky-ghost" hover-class="tap-active" bindtap="goContact">地址</button>
  </view>
</view>
