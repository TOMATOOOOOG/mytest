.contact-actions {
  margin-top: 24rpx;
}

.contact-card .card-text + .card-text {
  margin-top: 4rpx;
}

.service-card {
  padding: 32rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #edf3e8 100%);
  box-shadow: 0 16rpx 38rpx rgba(60, 50, 35, 0.07);
}

.service-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.service-label {
  color: #6d8b74;
  font-size: 24rpx;
  font-weight: 700;
}

.service-title {
  margin-top: 6rpx;
  color: #24352b;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.service-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #6d8b74;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
}

.service-desc {
  margin-top: 18rpx;
  color: #67645d;
  font-size: 27rpx;
}

.map-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
  box-shadow: 0 14rpx 34rpx rgba(60, 50, 35, 0.06);
}

.map-image {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #edf3e8;
}

.map-body {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx;
}

.map-button {
  width: 188rpx;
  flex: none;
}

.qr-card {
  padding: 34rpx;
  text-align: center;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(109, 139, 116, 0.16);
}

.qr-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 20rpx;
}

.map-note {
  color: #9a7d47;
  font-size: 24rpx;
  line-height: 1.6;
}
