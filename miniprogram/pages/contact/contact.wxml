<view class="page">
  <view class="hero">
    <view class="eyebrow">Contact</view>
    <view class="hero-title">联系我们</view>
    <view class="hero-text">如果您正在犹豫，可以先从一次沟通开始。第一版小程序不放预约表，优先通过微信客服、电话和地图完成联系。</view>
  </view>

  <view class="section service-card">
    <view class="service-card-head">
      <view>
        <view class="service-label">松境心理咨询顾问</view>
        <view class="service-title">先和我们简单聊聊</view>
      </view>
      <view class="service-badge">客服</view>
    </view>
    <view class="service-desc">说明您的主要困扰、希望线上或线下咨询、可沟通时间，我们会协助初步匹配。</view>
    <view class="action-grid contact-actions">
      <button class="action-button" hover-class="tap-active" bindtap="feedback" open-type="contact">微信咨询</button>
      <button class="ghost-button" hover-class="tap-active" bindtap="callPhone">拨打电话</button>
    </view>
  </view>

  <view class="section">
    <view class="card contact-card">
      <view class="card-title">电话</view>
      <view class="card-text">{{contact.phone}}</view>
    </view>
    <view class="card contact-card">
      <view class="card-title">邮箱</view>
      <view class="card-text">{{contact.email}}</view>
    </view>
    <view class="card contact-card">
      <view class="card-title">地址</view>
      <view class="card-text">{{contact.address}}</view>
    </view>
    <view class="card contact-card">
      <view class="card-title">工作时间</view>
      <view class="card-text" wx:for="{{contact.hours}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="section map-card" bindtap="openMap">
    <image class="map-image" src="/assets/images/contact-map-preview.jpg" mode="aspectFill"></image>
    <view class="map-body">
      <view>
        <view class="card-title">地图导航</view>
        <view class="card-text">{{contact.address}}</view>
      </view>
      <button class="ghost-button map-button" hover-class="tap-active" catchtap="openMap">打开地图</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">微信咨询二维码</view>
    <view class="qr-card">
      <image class="qr-image" src="{{contact.qrImage}}" mode="aspectFit"></image>
      <view class="card-text">如客服按钮暂不可用，可扫码添加咨询顾问。</view>
    </view>
  </view>

  <view class="map-note">{{contact.mapNote}}</view>
</view>
